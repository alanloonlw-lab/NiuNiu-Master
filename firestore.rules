rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches request.auth.uid)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - displayName: string (required) - User's name
    //   - photoURL: string (optional) - Profile pic
    //   - chips: number (required) - Current chips
    //   - totalScore: number (required) - Cumulative score
    //   - totalWins: number (optional) - Wins count
    //   - totalGames: number (optional) - Games count
    //   - createdAt: timestamp (required) - Creation time
    //   - lastPlayedAt: timestamp (required) - Last activity
    //
    // Collection: game_sessions
    // Document ID: {sessionId}
    // Fields:
    //   - sessionId: string (required)
    //   - playerUid: string (required) - Owner of the session
    //   - betAmount: number (required)
    //   - result: string (required) - win/loss/draw
    //   - multiplier: number (optional)
    //   - playerCards: list (optional)
    //   - dealerCards: list (optional)
    //   - timestamp: timestamp (required)
    //
    // Collection: leaderboard
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - chips: number (required)
    //   - totalScore: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // Collection: submissions
    // Document ID: {submissionId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (optional)
    //   - chips: number (required)
    //   - totalScore: number (required)
    //   - source: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "alanloo.nlw@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'chips', 'totalScore']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.chips is number && data.chips >= 0 &&
             data.totalScore is number &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             (!('role' in data) || data.role == 'user'); // Prevent self-promotion to admin
    }

    function isValidGameSession(data) {
      return data.keys().hasAll(['sessionId', 'playerUid', 'betAmount', 'result', 'timestamp']) &&
             data.playerUid == request.auth.uid &&
             data.betAmount is number && data.betAmount > 0 && data.betAmount < 1000000 &&
             data.result in ['win', 'loss', 'draw'] &&
             data.timestamp is timestamp &&
             data.sessionId is string && data.sessionId.size() > 0 && data.sessionId.size() < 100;
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['uid', 'displayName', 'chips', 'totalScore']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.chips is number && data.chips >= 0 &&
             data.totalScore is number;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['uid', 'displayName', 'chips', 'totalScore', 'source', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.chips is number && data.chips >= 0 &&
             data.totalScore is number &&
             data.source is string && data.source.size() > 0 && data.source.size() < 50 &&
             data.timestamp is timestamp &&
             (!('email' in data) || (data.email is string && data.email.size() > 0 && data.email.size() < 100));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /game_sessions/{sessionId} {
      allow read: if isAuthenticated() && (resource.data.playerUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidGameSession(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /leaderboard/{userId} {
      allow read: if true; // Guests can see the leaderboard
      allow create: if isOwner(userId) && isValidLeaderboardEntry(request.resource.data);
      allow update: if isOwner(userId) && isValidLeaderboardEntry(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
